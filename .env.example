# =============================================================================
# usbot — environment variable template
# -----------------------------------------------------------------------------
# This file documents the NAMES of the secrets/config the bot looks for.
# DO NOT put real keys, passwords or tokens here. Copy to `.env` for local dev
# (the .env file is git-ignored), or set these as GitHub Actions Secrets.
#
# Every key below is OPTIONAL. If a key is missing, the bot does NOT crash:
# the module that needs it is skipped gracefully and the report notes the skip.
# The MVP runs end-to-end with NONE of these set (yfinance + calendars only).
# =============================================================================

# --- Macro data (FRED) — Phase 2+ ---
FRED_API_KEY=

# --- News / fundamentals fallback — Phase 2+ ---
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
# Sentiment model override: vader (default, keyless) | finbert (needs [finbert] extra)
USBOT_SENTIMENT=vader

# --- LLM provider (configurable) — Phase 3+ ---
# LLM_PROVIDER one of: anthropic | openai | ollama | none   (default: none)
LLM_PROVIDER=none
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# For local Ollama (no key needed), set provider=ollama and optionally:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Email report (Gmail SMTP) — optional ---
# If SMTP_USERNAME or SMTP_APP_PASSWORD is missing, the report is logged to
# console/file instead of emailed.
SMTP_USERNAME=
SMTP_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_TO=anilkirikkanat@gmail.com
EMAIL_FROM=anilkirikkanat@gmail.com

# --- External trigger (cron-job.org -> GitHub repository_dispatch) ---
# Optional shared secret echoed by the workflow for sanity-checking the trigger.
CRON_SECRET_TOKEN=
