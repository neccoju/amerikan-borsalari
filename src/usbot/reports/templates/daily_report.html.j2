<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  body { font-family: -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
         color: #1a1a1a; max-width: 760px; margin: 0 auto; padding: 16px; }
  h1 { font-size: 20px; margin-bottom: 2px; }
  h2 { font-size: 15px; margin-top: 22px; border-bottom: 1px solid #eee; padding-bottom: 4px; }
  .muted { color: #777; font-size: 12px; }
  .regime { padding: 8px 12px; border-radius: 6px; display: inline-block; font-weight: 600; }
  .risk_on { background:#e6f4ea; color:#137333; }
  .risk_off { background:#fce8e6; color:#c5221f; }
  .neutral { background:#fef7e0; color:#b06000; }
  table { border-collapse: collapse; width: 100%; font-size: 13px; margin-top: 6px; }
  th, td { text-align: left; padding: 5px 8px; border-bottom: 1px solid #f0f0f0; }
  th { color:#555; font-weight:600; }
  .pos { color:#137333; } .neg { color:#c5221f; }
  .pill { background:#f1f3f4; border-radius:10px; padding:2px 8px; font-size:12px; }
  .warn { color:#b06000; } .err { color:#c5221f; }
  .footer { margin-top:24px; font-size:11px; color:#999; }
</style>
</head>
<body>
  <h1>usbot — Daily Report</h1>
  <div class="muted">{{ ctx.date }} · Market: {{ ctx.market_status }} ·
    Month-end rebalance: <b>{{ 'YES' if ctx.is_month_end else 'no' }}</b></div>

  {% if ctx.dashboard_url %}
  <div style="margin:14px 0;">
    <a href="{{ ctx.dashboard_url }}"
       style="display:inline-block; background:#137333; color:#ffffff; text-decoration:none;
              font-weight:600; font-size:14px; padding:10px 18px; border-radius:6px;">
      📊 Open Dashboard
    </a>
    <div class="muted" style="margin-top:6px;">
      Or copy this link: <a href="{{ ctx.dashboard_url }}">{{ ctx.dashboard_url }}</a>
    </div>
  </div>
  {% elif ctx.dashboard_generated %}
  <div class="muted" style="margin:14px 0;">
    Dashboard generated, but DASHBOARD_URL is not configured yet.
  </div>
  {% endif %}

  <h2>Macro Regime</h2>
  <span class="regime {{ ctx.regime_label }}">{{ ctx.regime_label|upper }}</span>
  <span class="muted">score {{ "%.0f"|format(ctx.regime_score) }}</span>
  {% if ctx.regime_detail %}
  <div class="muted" style="margin-top:6px;">
    {% for k, v in ctx.regime_detail.items() %}<span class="pill">{{ k }}: {{ v }}</span> {% endfor %}
  </div>
  {% endif %}

  {% for pf in ctx.portfolios %}
  <h2>{{ pf.name }}</h2>
  <div>
    Total value: <b>${{ "{:,.2f}".format(pf.total_value) }}</b> ·
    In shares: <b>${{ "{:,.2f}".format(pf.equity) }}</b> ·
    Cash: <b>${{ "{:,.2f}".format(pf.cash) }}</b> ·
    Daily: <span class="{{ 'pos' if pf.daily_pl >= 0 else 'neg' }}">{{ "%+.2f"|format(pf.daily_pl) }}</span> ·
    Total P/L: <span class="{{ 'pos' if pf.total_pl >= 0 else 'neg' }}">{{ "%+.2f"|format(pf.total_pl) }}</span>
  </div>
  {% if pf.holdings %}
  <table>
    <tr><th>Symbol</th><th>Weight</th><th>Shares</th><th>Fill</th><th>Price</th>
        <th>Value</th><th>P/L</th></tr>
    {% for h in pf.holdings[:15] %}
    <tr>
      <td>{{ h.symbol }}</td>
      <td>{{ "%.1f"|format(h.weight*100) }}%</td>
      <td>{{ "%.4f"|format(h.shares) }}</td>
      <td>${{ "{:,.2f}".format(h.avg_cost) }}</td>
      <td>${{ "{:,.2f}".format(h.price) }}</td>
      <td>${{ "{:,.2f}".format(h.value) }}</td>
      <td class="{{ 'pos' if h.pl_pct >= 0 else 'neg' }}">{{ "%+.1f"|format(h.pl_pct*100) }}%</td>
    </tr>
    {% endfor %}
  </table>
  {% else %}<div class="muted">No holdings (100% cash).</div>{% endif %}
  {% if pf.actions %}
  <div class="muted" style="margin-top:6px;">Actions:
    {% for a in pf.actions %}<div>· {{ a }}</div>{% endfor %}
  </div>{% endif %}
  {% endfor %}

  <h2>Transaction Ledger — {{ ctx.date }}</h2>
  <div class="muted">Today's cost: <b>${{ "{:,.2f}".format(ctx.cost_today) }}</b> ·
    Lifetime cost: <b>${{ "{:,.2f}".format(ctx.cost_total) }}</b></div>
  {% if ctx.ledger_today %}
  <table>
    <tr><th>Sleeve</th><th>Type</th><th>Symbol</th><th>Shares</th><th>Price</th><th>Fee</th><th>Reason</th></tr>
    {% for e in ctx.ledger_today %}
    <tr>
      <td>{{ e.sleeve }}</td>
      <td>{{ e.type|upper }}</td>
      <td>{{ e.symbol }}</td>
      <td>{{ "%.4f"|format(e.shares) if e.shares else "—" }}</td>
      <td>{{ "$%0.2f"|format(e.price) if e.price else "—" }}</td>
      <td>{{ "$%0.2f"|format(e.cost) if e.cost else "—" }}</td>
      <td class="muted">{{ e.reason }}</td>
    </tr>
    {% endfor %}
  </table>
  {% else %}
  <div class="muted">No trades today — positions held.</div>
  {% endif %}

  {% if ctx.top_scores %}
  <h2>Top Scores</h2>
  {% for pf_name, items in ctx.top_scores.items() %}
  <div><b>{{ pf_name }}:</b>
    {% for sym, val in items[:5] %}<span class="pill">{{ sym }} {{ "%.0f"|format(val) }}</span> {% endfor %}
  </div>
  {% endfor %}
  {% endif %}

  {% if ctx.news_highlights %}
  <h2>Important News</h2>
  <table>
    <tr><th>Symbol</th><th>Sentiment</th><th>Type</th><th>Headline</th></tr>
    {% for n in ctx.news_highlights[:12] %}
    <tr>
      <td>{{ n.symbol }}</td>
      <td class="{{ 'pos' if n.label == 'positive' else ('neg' if n.label == 'negative' else 'muted') }}">{{ n.label }}</td>
      <td><span class="pill">{{ n.category }}</span></td>
      <td>{{ n.headline[:110] }}</td>
    </tr>
    {% endfor %}
  </table>
  {% elif ctx.news_note %}
  <h2>News</h2>
  <div class="muted">{{ ctx.news_note }}</div>
  {% endif %}

  {% if ctx.institutional_updates %}
  <h2>Institutional (13F) Moves</h2>
  <table>
    <tr><th>Symbol</th><th>Change</th><th>Fund</th></tr>
    {% for u in ctx.institutional_updates[:12] %}
    <tr><td>{{ u.symbol }}</td>
        <td class="{{ 'pos' if u.change_type in ['new','increased'] else 'neg' }}">{{ u.change_type }}</td>
        <td>{{ u.fund }}</td></tr>
    {% endfor %}
  </table>
  {% elif ctx.institutional_note %}
  <h2>Institutional (13F)</h2><div class="muted">{{ ctx.institutional_note }}</div>
  {% endif %}

  {% if ctx.congress_updates %}
  <h2>Congressional Trades</h2>
  <table>
    <tr><th>Symbol</th><th>Type</th><th>Amount</th><th>Member</th><th>Chamber</th></tr>
    {% for u in ctx.congress_updates[:12] %}
    <tr><td>{{ u.symbol }}</td>
        <td class="{{ 'pos' if u.txn_type == 'buy' else 'neg' }}">{{ u.txn_type }}</td>
        <td>{{ u.amount_range }}</td><td>{{ u.politician }}</td><td>{{ u.chamber }}</td></tr>
    {% endfor %}
  </table>
  {% elif ctx.congress_note %}
  <h2>Congressional Trades</h2><div class="muted">{{ ctx.congress_note }}</div>
  {% endif %}

  <h2>LLM Review</h2>
  <div class="muted">{{ ctx.llm_note }}</div>

  {% if ctx.skipped %}
  <h2>Skipped Modules</h2>
  <div class="warn">{% for s in ctx.skipped %}<div>· {{ s }}</div>{% endfor %}</div>
  {% endif %}

  {% if ctx.data_gaps %}
  <h2>Data Gaps</h2>
  <div class="muted">{{ ctx.data_gaps|length }} symbol(s) had no price data and were
    skipped this run — this is normal (delisted/renamed/illiquid tickers, or a
    transient yfinance miss) and does not affect scored names:
    {{ ctx.data_gaps[:20]|join(", ") }}{% if ctx.data_gaps|length > 20 %} …{% endif %}</div>
  {% endif %}

  {% if ctx.errors %}
  <h2>Data / API Errors</h2>
  <div class="err">{% for e in ctx.errors[:15] %}<div>· {{ e }}</div>{% endfor %}</div>
  {% endif %}

  <div class="footer">
    Research and monitoring tool. NOT financial advice. All portfolios are
    simulated (paper trading). Self-Learning sleeve is paper-only.
  </div>
</body>
</html>
